{
  "name": "stream-media-board",
  "private": true,
  "version": "0.36.2",
  "description": "LAN clip dashboard and browser overlay for streaming — YouTube audio and video clips for any app with a browser source.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "fetch:bin": "node scripts/fetch-binaries.mjs",
    "fetch:node": "node scripts/fetch-node-runtime.mjs",
    "stage:win": "node scripts/stage-windows-dist.mjs",
    "installer:inno": "node scripts/build-installer-inno.mjs",
    "cert:make": "powershell -ExecutionPolicy Bypass -File scripts/make-selfsigned-cert.ps1 -AutoPassword",
    "cert:trust": "powershell -ExecutionPolicy Bypass -File scripts/trust-cert-on-target.ps1 -CertPath certs/stream-media-board-codesign.cer -Scope CurrentUser",
    "dist:signed": "powershell -ExecutionPolicy Bypass -File scripts/build-signed-installer.ps1",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm --workspace backend run start",
    "installer:win": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "publish:release": "node scripts/publish-release.mjs --skip-build",
    "publish:signed": "powershell -ExecutionPolicy Bypass -Command \"$env:SIGN_CERT_NAME='Stream Media Board'; node scripts/publish-release.mjs\"",
    "publish:win": "node scripts/publish-release.mjs",
    "release": "node scripts/release.mjs",
    "release:publish": "node scripts/release.mjs --publish-only"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mmartinewski/stream-media-board.git"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^4.19.0",
    "multer": "^2.1.1",
    "sharp": "^0.33.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
